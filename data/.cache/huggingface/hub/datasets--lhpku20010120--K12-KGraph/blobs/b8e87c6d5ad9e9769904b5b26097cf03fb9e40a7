4} + \\frac{2}{4} \\right)\n   \\]\n   \\[\n   g(1) = - \\frac{3}{4}\n   \\]\n\n8. Since \\( g(x) \\) is decreasing, the maximum value \\( -g(x) \\) can achieve in the interval \\( (-\\infty, 1) \\) is \\( \\frac{3}{4} \\). Hence:\n   \\[\n   - \\left( \\left(\\frac{1}{4}\\right)^x + \\left(\\frac{1}{2}\\right)^x \\right) \\leq - \\frac{3}{4}\n   \\]\n   Thus:\n   \\[\n   a \\geq - \\frac{3}{4}\n   \\]\n\n### Conclusion:\n\\[\n\\boxed{a \\geq -\\frac{3}{4}}\n\\]"}
