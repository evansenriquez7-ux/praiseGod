n        count = 0\n        for elem in a:\n            if elem in b:\n                count += 1\n        return count\n    if type(a) == dict:\n        count = 0\n        for key in a.keys():\n            if key in b.keys() and a[key] == b[key]:\n                count += 1\n        return count\n    if type(a) in [int, float, type(None)]:\n        return None\n    if type(a) == bool:\n        return None\n```"}
