ient.download_blob()\n        my_blob.write(download_stream.readall())\n\ndef delete_file(container_name, blob_name):\n    blob_service_client = BlobServiceClient.from_connection_string(connection_string)\n    container_client = blob_service_client.get_container_client(container_name)\n    blob_client = container_client.get_blob_client(blob_name)\n\n    blob_client.delete_blob()\n\nif __name__ == \"__main__\":\n    operation = sys.argv[1]\n\n    if operation == \"upload\":\n        container_name = sys.argv[2]\n        local_file_path = sys.argv[3]\n        upload_file(container_name, local_file_path)\n    elif operation == \"list\":\n        container_name = sys.argv[2]\n        list_files(container_name)\n    elif operation == \"download\":\n        container_name = sys.argv[2]\n        blob_name = sys.argv[3]\n        destination_folder = sys.argv[4]\n        download_file(container_name, blob_name, destination_folder)\n    elif operation == \"delete\":\n        container_name = sys.argv[2]\n        blob_name = sys.argv[3]\n        delete_file(container_name, blob_name)\n    else:\n        print(\"Invalid operation. Supported operations: upload, list, download, delete\")\n```\n\nTo use the script, you need to replace `your_connection_string_here` with your actual Azure Blob Storage connection string.\n\nHere's how to call the script from the command line:\n\n- To upload a file: `python azure_blob_storage.py upload mycontainer /path/to/local/file.txt`\n- To list files in a container: `python azure_blob_storage.py list mycontainer`\n- To download a specific file: `python azure_blob_storage.py download mycontainer myfile.txt /path/to/destination/folder`\n- To delete a specific file: `python azure_blob_storage.py delete mycontainer myfile.txt`"}
