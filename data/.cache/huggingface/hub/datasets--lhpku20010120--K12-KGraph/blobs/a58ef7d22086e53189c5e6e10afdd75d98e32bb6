e($\"Element {target} is present in the list\");\n        } else {\n            Console.WriteLine(\"Element not found in list\");\n        }\n    }\n\n    static bool BinarySearch(string[] arr, string target) {\n        int left = 0;\n        int right = arr.Length - 1;\n        while (left <= right) {\n            int mid = left + (right - left) / 2;\n            if (arr[mid] == target) {\n                return true;\n            } else if (string.Compare(arr[mid], target) < 0) {\n                left = mid + 1;\n            } else {\n                right = mid - 1;\n            }\n        }\n        return false;\n    }\n}\n```\n\nIn this modified code, we've replaced the `int` array `arr` with a `string` array `arr`, and `target` from `int` to `string`. We've also modified the `BinarySearch` function to compare strings using `string.Compare` method instead of integer comparison. Finally, we've modified the main method to take user input for the target string using the `Console.ReadLine()` method."}
