{"node_id": "bcaf189cacd95914b5776a5bf91de936", "title": "5.2 and 5.3 practice", "description": "Practice what you learned in lessons 5.2 and 5.3.", "topic_path": ["Khan Academy (English - US curriculum)", "Arts and humanities", "OER Project: Big History", "Agriculture & Complex Societies", "Complex Societies Appear | 5.3", "5.2 and 5.3 practice"], "assessment_items": [{"item_id": "7e354cefe4485795b8bccac88ef8e85c", "question_content": "**What is symbiosis?\n**\n\n[[☃ radio 1]]", "hints": [], "widget_types": ["radio"], "answer_data": {"radio 1": {"type": "radio", "choices": [{"content": "An interdependent relationship between different species\n\n", "correct": true}, {"content": "An interdependent relationship between the same species\n\n", "correct": false}, {"content": "A relationship in which two different species live near one another but do not interact\n\n", "correct": false}, {"content": "\nAn interdependent relationship between different species that is harmful to both species\n\n", "correct": false}]}}}, {"item_id": "3b09b802ee6550088d1b09bdb3dc497e", "question_content": "**What is another way to describe foraging?\n**\n\n[[☃ radio 1]]", "hints": [], "widget_types": ["radio"], "answer_data": {"radio 1": {"type": "radio", "choices": [{"content": "Hunting and gathering\n\n", "correct": true}, {"content": "Agriculture\n\n\n", "correct": false}, {"content": "Collective learning\n\n", "correct": false}, {"content": "Farming\n\n", "correct": false}]}}}, {"item_id": "7681226b4a13561a8f2f37d893be6435", "question_content": "**Which of the following directly increases human population?\n**\n\n[[☃ radio 1]]", "hints": [], "widget_types": ["radio"], "answer_data": {"radio 1": {"type": "radio", "choices": [{"content": "Food surpluses\n\n", "correct": true}, {"content": "Labor specialization\n\n", "correct": false}, {"content": "Irrigation\n\n", "correct": false}, {"content": "Rulers and governments\n\n", "correct": false}]}}}, {"item_id": "4fcc0aa817585e429b2f12b7a7c15ad2", "question_content": "**What is one similarity all early agrarian societies share?\n**\n\n[[☃ radio 1]]", "hints": [], "widget_types": ["radio"], "answer_data": {"radio 1": {"type": "radio", "choices": [{"content": "They all had social structures\n\n", "correct": true}, {"content": "They all followed a religion\n\n", "correct": false}, {"content": "They all only used farming to source food\n\n", "correct": false}, {"content": "They all developed writing systems\n\n", "correct": false}]}}}], "mastery_model": {"type": "m_of_n", "m": 3, "n": 4}, "randomize": true}