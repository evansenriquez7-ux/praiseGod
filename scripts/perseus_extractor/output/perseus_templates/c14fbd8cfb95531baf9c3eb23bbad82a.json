{"node_id": "c14fbd8cfb95531baf9c3eb23bbad82a", "title": "Substitution with negative numbers", "description": "Practice plugging in values to evaluate negative number addition and subtraction expressions.", "topic_path": ["Khan Academy (English - US curriculum)", "Math by grade", "Illustrative Mathematics", "7th grade (Illustrative Math-aligned)", "Rational number arithmetic", "Expressions with rational numbers", "Substitution with negative numbers"], "assessment_items": [{"item_id": "5f5d40cd3396570d9620ea4e65a27ee8", "question_content": "**Evaluate $a+(-b)$ where $a = 4$ and $b = 2$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{a = 4}$ and $\\maroonD{b = 2}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\blueD{a}+(-\\maroonD{b}) \\\\\\\\\n&= \\blueD{4}+\\left(-\\maroonD{2}\\right)\n\\end{align}$", "$= 4-2$", "$=2$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 2}]}}}, {"item_id": "9a7921c3fd135b25af468225271d5d0e", "question_content": "**Evaluate $-1-(-z)$ where $z = -2$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{z = -2}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} -1-(-\\blueD{z}) \\\\\\\\\n&= -1-\\left(-\\blueD{\\left(-2\\right)}\\right)\n\\end{align}$", "$= -1-2$", "$=-3$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -3}]}}}, {"item_id": "ab4457856865525094e018b71a7d24d3", "question_content": "**Evaluate $p+(-q)-2$ where $p = -3$ and $q = 5$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{p = -3}$ and $\\maroonD{q = 5}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\blueD{p}+(-\\maroonD{q})-2 \\\\\\\\\n&= \\blueD{\\left(-3\\right)}+\\left(-\\maroonD{5}\\right)-2\n\\end{align}$", "$\\begin{align}\n&= -3-5-2 \\\\\\\\\n&=-8-2\n\\end{align}$", "$=-10$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -10}]}}}, {"item_id": "a7ff366975c659239e7709011637d5a9", "question_content": "**Evaluate $3+(-h)+(-4)$ where $h = -7$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{h = -7}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} 3+(-\\blueD{h})+(-4) \\\\\\\\\n&= 3+\\left(-\\blueD{\\left(-7\\right)}\\right)+\\left(-4\\right)\n\\end{align}$", "$\\begin{align}\n&= 3+7-4 \\\\\\\\\n&=10-4\n\\end{align}$", "$=6$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 6}]}}}, {"item_id": "5d001f3571bb5a649cce34d6a8d207cf", "question_content": "**Evaluate $2-(-4)+(-y)$ where $y = 7$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{y = 7}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} 2-(-4)+(-\\blueD{y}) \\\\\\\\\n&= 2-\\left(-4\\right)+\\left(-\\blueD{7}\\right)\n\\end{align}$", "$\\begin{align}\n&= 2+4-7 \\\\\\\\\n&=6-7\n\\end{align}$", "$=-1$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -1}]}}}, {"item_id": "4d0930fa4740516a9119624b8b09cbed", "question_content": "**Evaluate $-3.28-(-4.4)+(-p)$ where $p = 9.7$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{p = 9.7}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} -3.28-(-4.4)+(-\\blueD{p}) \\\\\\\\\n&= -3.28-\\left(-4.4\\right)+\\left(-\\blueD{9.7}\\right)\n\\end{align}$", "$\\begin{align}\n&= -3.28+4.4-9.7 \\\\\\\\\n&=1.12 - 9.7\n\\end{align}$", "$=-8.58$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -8.58}]}}}, {"item_id": "67adefe5cd2359c89d8c30451e447205", "question_content": "**Evaluate $x-(-y)$ where $x = -2.31$ and $y = 5.9$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{x = -2.31}$ and $\\maroonD{y = 5.9}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\blueD{x}-(-\\maroonD{y}) \\\\\\\\\n&= \\blueD{\\left(-2.31\\right)}-\\left(-\\maroonD{5.9}\\right)\n\\end{align}$", "$= -2.31+5.9$", "$=3.59$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 3.59}]}}}, {"item_id": "0dc9f2e1f6ca54bab0dca65d5bf7cb90", "question_content": "**Evaluate $-a+(-b)$ where $a = 6.05$ and $b = 3.611$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{a = 6.05}$ and $\\maroonD{b = 3.611}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} -\\blueD{a}+(-\\maroonD{b}) \\\\\\\\\n&= -\\blueD{6.05}+\\left(-\\maroonD{3.611}\\right)\n\\end{align}$", "$= -6.05-3.611$", "$=-9.661$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -9.661}]}}}, {"item_id": "87fd93ba25ae5d6abb8b6179351ca861", "question_content": "**Evaluate $f-g+(-2)$ where $f = -3.005$ and $g = 4.7$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{f = -3.005}$ and $\\maroonD{g = 4.7}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\blueD{f}-\\maroonD{g}+(-2) \\\\\\\\\n&= \\blueD{\\left(-3.005\\right)}-\\maroonD{4.7}+\\left(-2\\right)\n\\end{align}$", "$= -3.005-4.7-2$", "$=-7.705-2$", "$=-9.705$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -9.705}]}}}, {"item_id": "7358d9c764e051ff9dd1a399d3c4e06b", "question_content": "**Evaluate $-y+(-z)+7.99$ where $y = 1.46$ and $z = 3.82$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{y = 1.46}$ and $\\maroonD{z = 3.82}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} -\\blueD{y}+(-\\maroonD{z})+7.99 \\\\\\\\\n&= -\\blueD{1.46}+\\left(-\\maroonD{3.82}\\right)+7.99\n\\end{align}$", "$= -1.46-3.82+7.99$", "$=-5.28+7.99$", "$=2.71$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 2.71}]}}}, {"item_id": "2bbaeea2cfeb5b0fb7459f463557c92a", "question_content": "**Evaluate $-\\dfrac{2}{5}-x+\\left(-\\dfrac{9}{10}\\right)$ where $x = \\dfrac{4}{5}$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{x = \\dfrac{4}{5}}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} -\\dfrac{2}{5}-\\blueD{x}+\\left(-\\dfrac{9}{10}\\right) \\\\\\\\\n&= -\\dfrac{2}{5}-\\blueD{\\dfrac{4}{5}}+\\left(-\\dfrac{9}{10}\\right)\n\\end{align}$", "$\\begin{align}\n&= -\\dfrac{2}{5}-\\dfrac{4}{5}-\\dfrac{9}{10} \\\\\\\\\n&=-\\dfrac{6}{5}-\\dfrac{9}{10}\n\\end{align}$", "$=-\\dfrac{21}{10}$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"answerForms": ["proper", "improper"], "maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -2.1}]}}}, {"item_id": "ec3a0d7aa9cc5915b90dff519e63b2e8", "question_content": "**Evaluate $1+\\left(-\\dfrac{2}{3}\\right)-(-m)$ where $m = \\dfrac{9}{2}$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{m = \\dfrac{9}{2}}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} 1+\\left(-\\dfrac{2}{3}\\right)-(-\\blueD{m}) \\\\\\\\\n&= 1+\\left(-\\dfrac{2}{3}\\right)-\\left(-\\blueD{\\dfrac{9}{2}}\\right)\n\\end{align}$", "$\\begin{align} \n&= 1-\\dfrac{2}{3}+\\dfrac{9}{2} \\\\\\\\\n&=\\dfrac{1}{3}+\\dfrac{9}{2}\n\\end{align}$", "$=\\dfrac{29}{6}$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"answerForms": ["proper", "improper"], "maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 4.833333333333333}]}}}, {"item_id": "94b0a7b97bb85b8d8767a920bc171079", "question_content": "**Evaluate $b-\\left(-\\dfrac{1}{8}\\right)+c$ where $b = 2$ and $c = -\\dfrac{7}{4}$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{b = 2}$ and $\\maroonD{c = -\\dfrac{7}{4}}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\blueD{b}-\\left(-\\dfrac{1}{8}\\right)+\\maroonD{c} \\\\\\\\\n&= \\blueD{2}-\\left(-\\dfrac{1}{8}\\right)+\\maroonD{\\left(-\\dfrac{7}{4}\\right)}\n\\end{align}$", "$= 2+\\dfrac{1}{8}-\\dfrac{7}{4}$", "$=\\dfrac{17}{8}-\\dfrac{7}{4}$", "$=\\dfrac{3}{8}$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"answerForms": ["proper", "improper"], "maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 0.375}]}}}, {"item_id": "1e34510afe99526494c99c9982e122ee", "question_content": "**Evaluate $w+(-x)-\\dfrac{2}{3}$ where $w = -\\dfrac{5}{9}$ and $x = \\dfrac{4}{3}$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{w = -\\dfrac{5}{9}}$ and $\\maroonD{x = \\dfrac{4}{3}}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\blueD{w}+(-\\maroonD{x})-\\dfrac{2}{3} \\\\\\\\\n&= \\blueD{\\left(-\\dfrac{5}{9}\\right)}+\\left(-\\maroonD{\\dfrac{4}{3}}\\right)-\\dfrac{2}{3}\n\\end{align}$", "\n$= -\\dfrac{5}{9}-\\dfrac{4}{3}-\\dfrac{2}{3}$", "$=-\\dfrac{17}{9}-\\dfrac{2}{3}$", "$=-\\dfrac{23}{9}$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"answerForms": ["proper", "improper"], "maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": -2.5555555555555554}]}}}, {"item_id": "bf76757088ea520a8844500daeef522c", "question_content": "**Evaluate $\\dfrac{3}{2}+(-k)+(-2)$ where $k = -\\dfrac{5}{2}$.**\n\n[[☃ numeric-input 1]]", "hints": ["Let's substitute $\\blueD{k = -\\dfrac{5}{2}}$ into the expression.\n\n$\\begin{align}\n&\\phantom{=} \\dfrac{3}{2}+(-\\blueD{k})+(-2) \\\\\\\\\n&= \\dfrac{3}{2}+\\left(-\\blueD{\\left(-\\dfrac{5}{2}\\right)}\\right)+\\left(-2\\right)\n\\end{align}$", "$\\begin{align}\n&= \\dfrac{3}{2}+\\dfrac{5}{2}-2 \\\\\\\\\n&= 4-2\n\\end{align}$", "$=2$"], "widget_types": ["numeric-input"], "answer_data": {"numeric-input 1": {"type": "numeric-input", "answers": [{"maxError": null, "message": "", "simplify": "required", "status": "correct", "strict": false, "value": 2}]}}}], "mastery_model": {"type": "m_of_n", "m": 5, "n": 7}, "randomize": true}